# Google Ads Conversion Tracking
# Get your ID from Google Ads: Tools > Conversions > New conversion action
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_CONVERSION_LABEL=XXXXXXXXXXXXX

# Database - same PostgreSQL as the bot
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@host:5432/database

# Admin Dashboard Password
ADMIN_PASSWORD=your_secure_password_here

# PayPal Payment Integration
# Get from https://developer.paypal.com → Apps & Credentials
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_SECRET=your_paypal_secret
PAYPAL_MODE=sandbox
PAYPAL_WEBHOOK_ID=your_webhook_id
